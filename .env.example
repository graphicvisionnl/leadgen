# =====================
# Supabase
# =====================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
# Server-only — NEVER expose to client code
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# =====================
# Anthropic (Claude)
# =====================
ANTHROPIC_API_KEY=sk-ant-api03-...

# =====================
# Apify
# =====================
APIFY_API_TOKEN=apify_api_...

# =====================
# Vercel Preview Deployments
# IMPORTANT: Use a SEPARATE Vercel account for client previews.
# Do NOT use your main graphicvision Vercel account here.
# =====================
VERCEL_API_TOKEN=...
VERCEL_TEAM_ID=team_...   # Optional — only needed for team accounts

# =====================
# SMTP (Hostinger)
# Hostinger SMTP instellingen: smtp.hostinger.com, poort 465 (SSL) of 587 (STARTTLS)
# =====================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=ezra@graphicvision.nl
SMTP_PASS=jouw-hostinger-wachtwoord

# =====================
# Screenshot fallback (optional but recommended)
# https://screenshotone.com — 500 free screenshots/month
# =====================
SCREENSHOT_ONE_API_KEY=

# =====================
# App config
# =====================
# Used by cron job authentication (Vercel sends this automatically)
CRON_SECRET=change-this-to-a-random-string
# The URL of your deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://leadgen.graphicvision.nl
